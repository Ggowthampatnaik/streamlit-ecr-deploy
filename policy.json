{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPushFromSpecificRole",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::493272324412:role/github-ecr-role"
      },
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:PutImage"
      ],
      "Resource": "arn:aws:ecr:us-east-1:493272324412:repository/streamlit-ecr-deploy"
    }
  ]
}
